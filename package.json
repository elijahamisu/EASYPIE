{
  "name": "easypie",
  "version": "1.0.0",
  "description": "A premium Nigerian Naira investment platform designed for high performance and security.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vercel dev",
    "start": "vercel dev",
    "build": "echo 'No custom build step required. Static files serving from root.'",
    "lint": "eslint \"**/*.js\"",
    "format": "prettier --write \"**/*.{html,css,js,json,md}\"",
    "deploy:preview": "vercel",
    "deploy:prod": "vercel --prod"
  },
  "keywords": [
    "fintech",
    "nigeria",
    "investment",
    "easypie",
    "naira",
    "supabase",
    "vanilla-js"
  ],
