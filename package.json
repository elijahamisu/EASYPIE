  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.39.7"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "vercel": "^33.5.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-username/easypie.git"
  },
  "bugs": {
    "url": "https://github.com/your-username/easypie/issues"
  }
