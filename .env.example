# -----------------------------------------------------------------------------
# EASYPIE - PROJECT ENVIRONMENT VARIABLES
# -----------------------------------------------------------------------------

# Supabase Configuration
# Obtain these from your Supabase Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-for-server-side-logic

# App Information
APP_NAME="EASYPIE"
APP_URL=http://localhost:3000
TIMEZONE="Africa/Lagos"

# Payment Configuration (Kuda Bank - Deposit Settings)
# These details will be displayed to users on the deposit page
KUDA_BANK_NAME="Kuda Bank"
KUDA_ACCOUNT_NUMBER="0000000000"
KUDA_ACCOUNT_NAME="EASYPIE INVESTMENTS"

# Security & Cron
# Used to verify requests to /api/cron.js (e.g., from Vercel Cron Jobs or GitHub Actions)
CRON_SECRET=your_long_random_string_here

# Investment Settings
MIN_DEPOSIT=1000
MIN_WITHDRAWAL=2000
CURRENCY_SYMBOL="₦"
CURRENCY_CODE="NGN"

# Admin Configuration
ADMIN_EMAIL=admin@easypie.com
