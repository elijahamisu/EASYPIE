# EASYPIE - Environment Variables Example
# Duplicate this file to .env and fill in your actual credentials

# --- SUPABASE CONFIGURATION ---
# Found in Supabase Project Settings > API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-public-anon-key

# --- SERVER-SIDE / ADMIN CONFIGURATION ---
# Service Role Key is required for Serverless Functions (CRON jobs/Admin actions)
# Keep this secret! Do not expose it in the frontend.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- PLATFORM CONFIGURATION ---
APP_NAME="EASYPIE"
APP_URL=http://localhost:3000
TIMEZONE="Africa/Lagos"
CURRENCY_SYMBOL="₦"
CURRENCY_CODE="NGN"

# --- DEPOSIT CONFIGURATION (KUDA BANK) ---
# These details will be shown to users on the deposit page
KUDA_ACCOUNT_NAME="EASYPIE INVESTMENTS"
KUDA_ACCOUNT_NUMBER="0123456789"
KUDA_BANK_NAME="Kuda Bank"

# --- SECURITY ---
# A secret key to authorize internal cron jobs (e.g., daily earnings) 
# to prevent unauthorized triggers of serverless functions.
CRON_SECRET="your-high-entropy-secret-string"

# --- BUSINESS LOGIC ---
MIN_DEPOSIT=1000
MIN_WITHDRAWAL=2000
REFERRAL_PERCENTAGE=5
